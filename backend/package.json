{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/dashboard/main",
    "start:dev:dashboard": "nest start dashboard --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "dashboard:prisma:format": "dotenv -e .env -- prisma format --config=apps/dashboard/src/infra/prisma/prisma.config.ts --schema=apps/dashboard/src/infra/prisma/schema.prisma",
    "dashboard:prisma:migrate": "dotenv -e .env -- prisma migrate dev --config=apps/dashboard/src/infra/prisma/prisma.config.ts --schema=apps/dashboard/src/infra/prisma/schema.prisma",
    "dashboard:prisma:generate": "dotenv -e .env -- prisma generate --config=apps/dashboard/src/infra/prisma/prisma.config.ts --schema=apps/dashboard/src/infra/prisma/schema.prisma",
    "dashboard:prisma:reset": "dotenv -e .env -- prisma migrate reset --config=apps/dashboard/src/infra/prisma/prisma.config.ts --schema=apps/dashboard/src/infra/prisma/schema.prisma",
    "dashboard:prisma:seed": "dotenv -e .env -- prisma db seed --config=apps/dashboard/src/infra/prisma/prisma.config.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:dashboard": "jest --testPathPatterns=apps/dashboard"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "11.0.3",
    "@nestjs/microservices": "11.1.17",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "11.2.6",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "@prisma/client-runtime-utils": "7.5.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.3.1",
    "pg": "8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1",
      "^apps/(.*)$": "<rootDir>/apps/$1"
    }
  }
}
